# ─── GitInsight 环境变量配置 ───────────────────────
# 复制此文件为 .env 并填入实际值后使用
# cp .env.example .env
# ────────────────────────────────────────────────────

# === 数据库 ===
# PostgreSQL 连接字符串
DATABASE_URL="postgres://gitinsight:gitinsight@localhost:5432/gitinsight"

# === Redis ===
# Redis 连接字符串（用于作业队列）
REDIS_URL="redis://localhost:6379"

# === 分析作业 ===
# 作业存储方式：memory | prisma
ANALYSIS_JOB_STORE="memory"
# 作业分发模式：inline | queue
ANALYSIS_JOB_DISPATCH_MODE="queue"
# 队列执行模式：inprocess | bullmq
ANALYSIS_JOB_QUEUE_EXECUTION_MODE="inprocess"

# === 定时分析 ===
# 是否启用定时分析
SCHEDULED_ANALYSIS_ENABLED="false"
# 定时分析间隔（毫秒）
SCHEDULED_ANALYSIS_INTERVAL_MS="3600000"
# 定时分析的仓库列表（逗号分隔）
SCHEDULED_ANALYSIS_REPOS=""

# === Web 前端 ===
# API 基础地址（前端侧使用）
NEXT_PUBLIC_API_URL="http://localhost:3000"

# === 服务端口 ===
# API 端口（默认 3000）
PORT="3000"
