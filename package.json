{
  "name": "gitinsight",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "test": "vitest run",
    "test:e2e:playwright": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:playwright:ui": "playwright test --ui --config e2e/playwright.config.ts",
    "benchmark": "vitest run tests/performance",
    "benchmark:watch": "vitest tests/performance"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "playwright": "^1.61.1",
    "vitest": "^2.1.8"
  }
}
